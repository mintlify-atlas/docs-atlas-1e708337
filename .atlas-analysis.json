  "keyFeatures": [
    "Multi-role user management: Administrators, Students, and Teachers with distinct permissions",
    "Flexible membership system with Basic, Intensive, Premium, and Personalized tiers",
    "Group and personalized class scheduling with reservation lifecycle management",
    "Teacher contract management with salary, hours tracking, and performance ratings",
    "File-based persistence using Java serialization for all entities",
    "Swing-based desktop GUI with custom blue theme",
    "Class rating and attendance tracking system",
    "Capital management for the academy (inject/withdraw funds)"
  ],
